// Parse the JSON response to get the Base64 encoded string
def jsonResponse = new JsonSlurper().parseText(response)
def base64Data = jsonResponse.data
log.info(&quot;RESPONSE BASE64 : ${base64Data}&quot;)

// Decode the Base64 encoded data
byte[] decodedBytes = Base64.getDecoder().decode(base64Data)
String decodedString = new String(decodedBytes, &quot;UTF-8&quot;)

// Parse the decoded JSON string
def decodedJson = new JsonSlurper().parseText(decodedString)

// Pretty print the decoded JSON
String prettyPrintedJson = JsonOutput.prettyPrint(JsonOutput.toJson(decodedJson))

// Log the pretty printed JSON for debugging
log.info(&quot;Pretty Printed Decoded JSON:\n${prettyPrintedJson}&quot;)

// Extract the value of transactionNo
def transactionNo = decodedJson.data.transactionNo
def qrisData = decodedJson.data.qrisData

// Log the transactionNo for debugging
log.info(&quot;Transaction No: ${transactionNo}&quot;)
log.info(&quot;QRIS Data: ${qrisData}&quot;)

// Save the transactionNo to a JMeter variable
props.put(&quot;transactionNo&quot;, transactionNo)
props.put(&quot;qrisData&quot;, qrisData)
log.info(&quot;--------------------Post-Processor End--------------------&quot;)

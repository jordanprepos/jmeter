            <stringProp name="script">import groovy.json.JsonSlurper
import groovy.json.JsonOutput
import java.util.Base64

log.info(&quot;--------------------Post-Proccess Start-----------------&quot;)
// Get the response data
def responseData = prev.getResponseDataAsString()

// Parse the response data to extract JSON
def jsonSlurper = new JsonSlurper()
def json = jsonSlurper.parseText(responseData)

// Extract the value of the jsonResponse field
def jsonResponse = json.data

// Log the extracted JSON response
log.info(&quot;Extracted JSON Response: $jsonResponse&quot;)

// Store the extracted JSON response in a JMeter variable for later use
vars.put(&quot;jsonResponse&quot;, jsonResponse)

// Decode Base64
byte[] decodedBytes = Base64.getDecoder().decode(jsonResponse)
def decodedString = new String(decodedBytes)

// Log the decoded string
log.info(&quot;Decoded Response: &quot; + decodedString)

// Pretty print the JSON response
def prettyJson = JsonOutput.prettyPrint(decodedString)
log.info(&quot;Decoded Response: &quot; + prettyJson)

// Store the decoded string in a JMeter variable for later use
vars.put(&quot;decodedString&quot;, decodedString)


log.info(&quot;--------------------Post-Proccess End-----------------&quot;)</stringProp>

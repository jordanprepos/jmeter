            <stringProp name="parameters"></stringProp>
            <stringProp name="script">import groovy.json.JsonBuilder
import groovy.json.JsonOutput
import java.security.MessageDigest
import java.util.Random

Random random = new Random()
String randomTrnNo = random.nextInt(1000000000)
String randomRefNo = random.nextInt(1000000000)

//def jsonMap = [:]
def valueLogin = &quot;${login}&quot;
def valuePassword = &quot;${password}&quot;
def valueSecret = &quot;${secretKey}&quot;
def valueMerchantId = &quot;${merchantId}&quot;
def valueStoreId = &quot;${storeId}&quot;
def valuePosId = &quot;${posId}&quot;
def valueTrnNo = randomTrnNo
def valueRefNo = randomRefNo
def valueAmount = &quot;${amount}&quot;
def valueValidTime = &quot;${validTime}&quot;
def valueStoreName = &quot;${storeName}&quot;
def valueCityName = &quot;${cityName}&quot;
def sign = valueLogin + valuePassword + valueMerchantId + valueStoreId + valuePosId + valueTrnNo + valueRefNo + valueAmount + valueValidTime + valueStoreName + valueCityName + valueSecret;
log.info(&quot;SIGNATURE : ${sign}&quot;)

def md5Signature = sign.md5()
vars.put(&quot;md5Signature&quot;, md5Signature)
log.info(&quot;md5Sign : ${md5Signature}&quot;)
log.info(&quot;valueSign : &quot; + md5Signature)
def valueSign = &quot;${md5Signature}&quot;

def jsonMap = [
    login: valueLogin,
    password: valuePassword,
    merchantId: valueMerchantId,
    storeId: valueStoreId,
    posId: valuePosId,
    transactionNo: valueTrnNo,
    referenceNo: valueRefNo,
    amount: valueAmount,
    validTime: valueValidTime,
    storeName: valueStoreName,
    cityName: valueCityName,
    signature: valueSign,
]


// Convert JSON data to JSON string
def jsonMapped = JsonOutput.toJson(jsonMap)
//def jsonRequestBody = new groovy.json.JsonBuilder(jsonMap).toPrettyString()
def jsonRequestBody = JsonOutput.prettyPrint(jsonMapped)


/*
Create MD5 hash using java.security.MessageDigest
*/
String stringToHash = jsonRequestBody
MessageDigest md = MessageDigest.getInstance(&quot;MD5&quot;)
md.update(stringToHash.getBytes())
byte[] digest = md.digest()

// Convert the byte array to hexadecimal string
StringBuilder hexString = new StringBuilder()
for (byte b : digest) {
    hexString.append(String.format(&quot;%02x&quot;, b &amp; 0xff))
}
String md5Hash = hexString.toString()

def md5Hashed = md5Hash 
props.put(&quot;md5Hashed&quot;,md5Hashed)
//log.info(&quot;md5-MsgDirect: ${md5Hashed}&quot;)

// Convert JSON string to UTF-8 encoded byte array
def utf8Bytes = jsonRequestBody.getBytes(&quot;UTF-8&quot;)

// Encode UTF-8 encoded byte array to Base64
def base64EncodedString = utf8Bytes.encodeBase64().toString()
props.put(&quot;base64EncodedString&quot;,base64EncodedString)

log.info(&quot;Mapped JSON : ${jsonMapped}&quot;)
log.info(&quot;PRECODED :\n${jsonRequestBody}&quot;)
log.info(&quot;UTF-8 : ${utf8Bytes}&quot;)
log.info(&quot;REQUEST BASE64 : ${base64EncodedString}&quot;)
log.info(&quot;--------------------Pre-Processor End--------------------&quot;)


</stringProp>

// Extract the value on data
def transactionNo = decodedJson.data.transactionNo
def issuerID = decodedJson.data.issuerID
def paymentReferenceNo = decodedJson.data.paymentReferenceNo
def retrievalReferenceNo = decodedJson.data.retrievalReferenceNo

// Log the transactionNo for debugging
log.info(&quot;Transaction No: ${transactionNo}&quot;)
log.info(&quot;Issuer ID: ${issuerID}&quot;)
log.info(&quot;Payment Reference No: ${paymentReferenceNo}&quot;)
log.info(&quot;Retrieval Reference No: ${retrievalReferenceNo}&quot;)

// Save the transactionNo to a JMeter variable
props.put(&quot;transactionNo&quot;, transactionNo)
props.put(&quot;issuerID&quot;, issuerID)
props.put(&quot;paymentReferenceNo&quot;, paymentReferenceNo)
props.put(&quot;retrievalReferenceNo&quot;, retrievalReferenceNo)
log.info(&quot;--------------------Post-Processor End--------------------&quot;)

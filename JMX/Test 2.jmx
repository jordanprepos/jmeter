def valueStoreId = &quot;${storeId}&quot;
def valuePosId = &quot;${posId}&quot;
def valueTrnNo = randomTrnNo
def valueRefNo = randomRefNo
def valueAmount = &quot;${amount}&quot;
def valueValidTime = &quot;${validTime}&quot;
def valueIssuerID = &quot;${__property(issuerID)}&quot;
def valuePaymentReferenceNo = &quot;${__property(paymentReferenceNo)}&quot;
def valueRetrievalReferenceNo = &quot;${__property(retrievalReferenceNo)}&quot; 
def sign = valueLogin + valuePassword + valueMerchantId + valueStoreId + valuePosId + valueTrnNo + valueRefNo + valueAmount + valuePaymentReferenceNo + valueIssuerID + valueRetrievalReferenceNo + valueSecret;

          <stringProp name="script">String res=prev.getResponseDataAsString();
String req = sampler.getArguments().getArgument(0).getValue().toString();
String responseHeader= prev.getResponseHeaders();
String url = sampler.getUrl();
String requestHeader = sampler.getHeaderManager().getHeaders().toString();

String folder = &apos;${pathFolder}&apos;;
String env = &apos;${env}&apos;;
String name = &apos;${__threadGroupName}&apos;;

File f = new File(folder + env + &apos; - &apos;+ name + &apos;.txt&apos;);
FileWriter fstream = new FileWriter(f.getPath(),true);

fstream.write(&apos;\n&apos;);
fstream.write(&apos;URL: &apos; + url + &apos;\n&apos;);
fstream.write(&apos;\nREQUEST HEADER: \n\n&apos;);
for (int i = 0; i &lt; sampler.getHeaderManager().size(); i++) {
    String header = sampler.getHeaderManager().getHeader(i)
    fstream.write(header + &apos;\n&apos;);
}

fstream.write(&apos;\nREQUEST BODY: \n\n&apos; + req + &apos;\n&apos;);
fstream.write(&apos;\nRESPONSE HEADER: \n\n&apos;+ responseHeader + &apos;\n&apos;);
fstream.write(&apos;\nRESPONSE BODY: \n\n&apos;+ res + &apos;\n&apos;);
fstream.write(&apos;\n\n---------------------------------------------------------------------------------------\n\n&apos;);
fstream.close();</stringProp>

// partnerReferenceNo max 64
String maxPartnerReferenceNo = &quot;${__RandomString(65,abcdefghijklmnopqrstuvwxyz1234567890,)}&quot;;
props.put(&quot;maxPartnerReferenceNo&quot;,maxPartnerReferenceNo);

// AccountNo max 16
String maxAccountNo = &quot;${__RandomString(17,1234567890,)}&quot;;
props.put(&quot;maxAccountNo&quot;,maxAccountNo);

// Name max 128
String specialCharPartnerRefNo = &quot;${__RandomString(16,!@#$%&amp;*,)}&quot;;
props.put(&quot;specialCharPartnerRefNo&quot;,specialCharPartnerRefNo);

// Email max 254
String specialCharAccountNo = &quot;${__RandomString(11,!@#$%&amp;*,)}&quot;;
props.put(&quot;specialCharAccountNo&quot;,specialCharAccountNo);
</stringProp>

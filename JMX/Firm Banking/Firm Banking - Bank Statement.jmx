            <stringProp name="script">import groovy.json.JsonSlurper
import groovy.json.JsonOutput
import groovy.json.JsonBuilder
import org.apache.commons.codec.digest.DigestUtils

def request = new JsonSlurper().parseText(sampler.getArguments().getArgument(0).getValue().toString()) 
def builder = new JsonBuilder(request)
def databody = JsonOutput.toJson(builder.content)
def method = sampler.getMethod();
def apikey = props.get(&quot;b2bToken&quot;);
def time = &quot;${__property(time)}&quot;;
def path = sampler.getUrl().getPath();
def secretKey = &quot;${clientSecret}&quot;;
def sha256 = org.apache.commons.codec.digest.DigestUtils.sha256Hex(databody);
def hmacdata = method + &quot;:&quot; + path + &quot;:&quot; + apikey + &quot;:&quot; + sha256 + &quot;:&quot; + time;
def hmacSHA = org.apache.commons.codec.digest.HmacUtils.hmacSha512Hex(secretKey, hmacdata);

//log.info(&quot;b2b token: &quot; + props.get(&quot;b2bToken&quot;))

def signature = hmacSHA
log.info(&quot;databody: &quot;+ databody);
log.info(&quot;apikey/b2bToken: &quot;+ apikey);
log.info(&quot;secretKey: &quot; + secretKey);
log.info(&quot;hmacdata: &quot; + hmacdata);
log.info(&quot;signature: &quot; + hmacSHA);
log.info(&quot;time: &quot;+ time);
vars.put(&quot;sign&quot;, hmacSHA);

// Calculate the HMAC-SHA-512 hash
println(&quot;Calculated HMAC-SHA-512: $hmacSHA&quot;)
// Compare with the provided signature
if (hmacSHA == signature) {
    log.info(&quot; &gt;&gt;&gt;&gt;&gt;&gt;&gt;&gt;&gt;&gt;&gt;&gt;&gt;&gt;&gt; Signature matches. Request integrity is verified.&quot;)
} else {
    log.info(&quot;&gt;&gt;&gt;&gt;&gt;&gt;&gt;&gt;&gt;&gt;&gt;&gt;&gt;&gt;&gt; Signature does not match. Request integrity is compromised.&quot;)
}

</stringProp>

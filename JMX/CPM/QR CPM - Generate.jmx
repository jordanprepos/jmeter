            <stringProp name="script">import groovy.json.JsonSlurper;
import groovy.json.JsonOutput
import groovy.json.JsonBuilder
import org.apache.commons.codec.digest.DigestUtils

def jsonRequest = new JsonSlurper().parseText(sampler.getArguments().getArgument(0).getValue().toString());
def json = new groovy.json.JsonSlurper().parseText(prev.getResponseDataAsString())
def builder = new JsonBuilder(json)

//vars.put(&quot;partnerReferenceNo&quot;, jsonRequest.partnerReferenceNo);
props.put(&quot;partnerReferenceNo&quot;, jsonRequest.partnerReferenceNo);
props.put(&quot;qrContent&quot;, json.qrContent);


log.info(JsonOutput.toJson(builder.content))
prev.setResponseData(JsonOutput.prettyPrint(JsonOutput.toJson(builder.content)), &quot;UTF-8&quot;)</stringProp>

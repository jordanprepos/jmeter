          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="JSR223 PreProcessor" enabled="true">
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="script">import java.security.*;
import java.security.spec.*;
import java.util.Base64;

String privateKeyString = &quot;${privateKey}&quot;;
String applyToken = &quot;${clientId}&quot;+&quot;|&quot;+&quot;${__property(time)}&quot;;

// Remove the BEGIN and END lines, and any newline characters
privateKeyString = privateKeyString.replaceAll(&quot;-----BEGIN RSA PRIVATE KEY-----&quot;, &quot;&quot;)
        .replaceAll(&quot;-----END RSA PRIVATE KEY-----&quot;, &quot;&quot;)
        .replaceAll(&quot;\n&quot;, &quot;&quot;)
        .replaceAll(&quot; &quot;, &quot;&quot;)
        .replaceAll(&quot;\r&quot;, &quot;&quot;)

// Decode base64
byte[] privateKeyBytes = Base64.getDecoder().decode(privateKeyString);

// Generate PrivateKey object
EncodedKeySpec privKeySpec = new PKCS8EncodedKeySpec(privateKeyBytes);
KeyFactory kf = KeyFactory.getInstance(&quot;RSA&quot;);
PrivateKey privateKey = kf.generatePrivate(privKeySpec);

def generateSignature(String input, PrivateKey privateKey) {
    try {
        Signature signature = Signature.getInstance(&quot;SHA256withRSA&quot;);
        signature.initSign(privateKey);
        signature.update(input.getBytes(&quot;UTF-8&quot;));
        byte[] signedBytes = signature.sign();
        return Base64.getEncoder().encodeToString(signedBytes);
    } catch (NoSuchAlgorithmException | InvalidKeyException | SignatureException | UnsupportedEncodingException e) {
        e.printStackTrace();
        return null;
    }
}

def signature = generateSignature(applyToken, privateKey);
vars.put(&quot;signature&quot;, signature);

log.info(&quot;applyToken: &quot;+ applyToken);
log.info(&quot;signature: &quot;+ signature);</stringProp>
            <stringProp name="scriptLanguage">groovy</stringProp>
          </JSR223PreProcessor>

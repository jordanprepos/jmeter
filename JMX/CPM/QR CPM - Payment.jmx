            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">// JSR223 PostProcessor code
String requestBody = &quot;&quot;;

// If the request is a POST or similar, we can use sampler.getArguments()
if (sampler.getArguments() != null &amp;&amp; sampler.getArguments().getArgumentCount() &gt; 0) {
    requestBody = sampler.getArguments().getArgument(0).getValue(); // Gets the first argument
} else {
    log.warn(&quot;No request body found in arguments.&quot;);
}

// For logging purposes
String method = sampler.getMethod(); // Get the HTTP method
log.info(&quot;HTTP Method: &quot; + method);
log.info(&quot;Request body: &quot; + requestBody); // Log the request body

if (requestBody != null &amp;&amp; !requestBody.isEmpty()) {
    vars.put(&quot;REQUEST_BODY&quot;, requestBody); // Store it in the REQUEST_BODY variable
    props.put(&quot;REQUEST_BODY&quot;, requestBody); 
    log.info(&quot;Request body captured: &quot; + requestBody);
} else {
    log.warn(&quot;Request body is null or empty.&quot;);
}
</stringProp>

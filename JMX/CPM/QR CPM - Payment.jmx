                <stringProp name="Header.value">${__property(Auth)}</stringProp>
              </elementProp>
              <elementProp name="" elementType="Header">
                <stringProp name="Header.name">X-SIGNATURE</stringProp>
                <stringProp name="Header.value">${__property(Signature)}</stringProp>
              </elementProp>
              <elementProp name="" elementType="Header">
                <stringProp name="Header.name">sof</stringProp>
                <stringProp name="Header.value">02</stringProp>
              </elementProp>
              <elementProp name="Content-Type" elementType="Header">

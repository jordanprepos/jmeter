          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="JSR223 PreProcessor" enabled="true">
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="script">import javax.crypto.Mac
import javax.crypto.spec.SecretKeySpec
import java.nio.charset.StandardCharsets
import java.security.MessageDigest
import groovy.json.JsonOutput
import groovy.json.JsonSlurper
import java.time.Instant

// Fetching necessary data from JMeter variables instead of `prev`
def channelID = &quot;${channelId}&quot;
def secret = &quot;${SecretOpenBanking}&quot;

if (channelID == &apos;APIMGM&apos;) {
    secret = &quot;${SecretAPIMGM}&quot;
}

if (channelID in [&apos;SuperApp&apos;, &apos;SuperAppGW&apos;, &apos;Nobubiz&apos;]) {
    secret = &quot;nobu123&quot;
}

// Get timestamp
def timestamp = Instant.now().toString()
log.info(&quot;ts= &quot; + timestamp)

// Generate token
def token = &quot;${channelID}:${secret}:${timestamp}&quot;.getBytes(StandardCharsets.UTF_8)
log.info(&quot;strToSignToken= ${channelID}:${secret}:${timestamp}&quot;)

// Generate MD5 token
def md5Token = MessageDigest.getInstance(&quot;MD5&quot;).digest(token).encodeHex().toString()
log.info(&quot;md5= &quot; + md5Token)

// Get method and URL from JMeter variables
def server = sampler.getDomain() // Get the server name or IP address from the sampler
def method = sampler.getMethod() // Get the HTTP method
def urlPath = sampler.getUrl().getPath() // Get the URL path
def requestBody = props.get(&quot;REQUEST_BODY&quot;) // Access REQUEST_BODY if stored as a property

if (requestBody != null) {
    log.info(&quot;Captured REQUEST_BODY: &quot; + requestBody);
} else {
    log.warn(&quot;REQUEST_BODY variable is not set.&quot;);
}


if (requestBody) {
    try {
        def parsedBody = new JsonSlurper().parseText(requestBody)
        log.info(&quot;Parsed request body: &quot; + parsedBody)
        
        // Generate SHA-256 hash of the request body
        def hashBody = MessageDigest.getInstance(&quot;SHA-256&quot;)
                          .digest(JsonOutput.toJson(parsedBody).getBytes(StandardCharsets.UTF_8))
                          .encodeHex().toString()
        log.info(&quot;sha256= &quot; + hashBody)
        
        // Create the string to sign
        def signString = &quot;${method}:${urlPath}:${hashBody}:${timestamp}&quot;
        log.info(&quot;signString signature= ${signString}&quot;)

        // Generate HMAC SHA-512 signature
        def mac = Mac.getInstance(&quot;HmacSHA512&quot;)
        def secretKeySpec = new SecretKeySpec(secret.getBytes(StandardCharsets.UTF_8), &quot;HmacSHA512&quot;)
        mac.init(secretKeySpec)
        def sign = mac.doFinal(signString.getBytes(StandardCharsets.UTF_8)).encodeBase64().toString()
        log.info(&quot;hmac sha512 signature= &quot; + sign)

        // Store the MD5 token and signature in JMeter properties
        props.put(&quot;Auth&quot;, md5Token)
        props.put(&quot;Signature&quot;, sign)
        props.put(&quot;Timestamp&quot;, timestamp)

    } catch (Exception e) {
        log.error(&quot;Error parsing request body: &quot; + e.message)
    }
} else {
    log.warn(&quot;Request body is null or empty&quot;)
}
</stringProp>

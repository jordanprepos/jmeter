      <BeanShellPreProcessor guiclass="TestBeanGUI" testclass="BeanShellPreProcessor" testname="BeanShell PreProcessor" enabled="true">
        <boolProp name="resetInterpreter">false</boolProp>
        <stringProp name="parameters"></stringProp>
        <stringProp name="filename"></stringProp>
        <stringProp name="script">String time = &quot;${__time(yyyy-MM-dd&apos;T&apos;HH:mm:ss+07:00)}&quot;;
props.put(&quot;time&quot;,time);


//partnerReferenceNo max 64
String maxPartnerReferenceNo = &quot;${__RandomString(65,abcdefghijklmnopqrstuvwxyz1234567890,)}&quot;;
props.put(&quot;maxPartnerReferenceNo&quot;,maxPartnerReferenceNo);

//qrContent max 512
String maxQrContent = &quot;${__RandomString(513,abcdefghijklmnopqrstuvwxyz1234567890,)}&quot;;
props.put(&quot;maxQrContent&quot;, maxQrContent);

//amount value max 64
String maxAmountValue = &quot;${__RandomString(17,1234567890,)}&quot;;
props.put(&quot;maxAmountValue&quot;,maxAmountValue);

//merchantId max 64
String maxMerchantId = &quot;${__RandomString(65,1234567890,)}&quot;;
props.put(&quot;maxMerchantId&quot;,maxMerchantId);

// subMerchantId max 32
String maxSubMerchantId = &quot;${__RandomString(33,1234567890,)}&quot;;
props.put(&quot;maxSubMerchantId&quot;,maxSubMerchantId);

// storeId max 64
String maxStoreId = &quot;${__RandomString(65,1234567890,)}&quot;;
props.put(&quot;maxStoreId&quot;,maxStoreId);

// terminalId max 16
String maxTerminalId = &quot;${__RandomString(17,1234567890,)}&quot;;
props.put(&quot;maxTerminalId&quot;,maxTerminalId);

// merchantName max 64
String maxMerchantName = &quot;${__RandomString(65,abcdefghijklmnopqrstuvwxyz1234567890,)}&quot;;
props.put(&quot;maxMerchantName&quot;,maxMerchantName);

// merchantLocation max 40
String maxMerchantLocation = &quot;${__RandomString(41,abcdefghijklmnopqrstuvwxyz1234567890,)}&quot;;
props.put(&quot;maxMerchantLocation&quot;,maxMerchantLocation);

// terminalId max 25
String maxTerminalId = &quot;${__RandomString(26,abcdefghijklmnopqrstuvwxyz1234567890,)}&quot;;
props.put(&quot;maxTerminalId&quot;,maxTerminalId);

// expiryTime max 25
String maxExpiryTime = &quot;${__RandomString(26,abcdefghijklmnopqrstuvwxyz1234567890,)}&quot;;
props.put(&quot;maxExpiryTime&quot;,maxExpiryTime);

// qrType max 6
String maxQrType = &quot;${__RandomString(7,abcdefghijklmnopqrstuvwxyz1234567890,)}&quot;;
props.put(&quot;maxQrType&quot;,maxQrType);

</stringProp>
      </BeanShellPreProcessor>

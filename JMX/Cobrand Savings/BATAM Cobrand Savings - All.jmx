          <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="JSR223 PostProcessor" enabled="true">
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="script">import groovy.json.JsonSlurper;
import groovy.json.JsonOutput
import groovy.json.JsonBuilder
import org.apache.commons.codec.digest.DigestUtils

def jsonRequest = new JsonSlurper().parseText(sampler.getArguments().getArgument(0).getValue().toString());
def json = new groovy.json.JsonSlurper().parseText(prev.getResponseDataAsString())
def builder = new JsonBuilder(json)

props.put(&quot;partnerReferenceNo&quot;, json.partnerReferenceNo);
props.put(&quot;referenceNo&quot;, json.referenceNo);
// Get the header manager from the sampler
def headers = sampler.getHeaderManager()

def externalIdValue = null

if (headers != null) {
    headers.getHeaders().each { header -&gt;
        if (header.getName().equalsIgnoreCase(&quot;X-EXTERNAL-ID&quot;)) {
            externalIdValue = header.getValue()
            log.info(&quot;X-EXTERNAL-ID Value: ${externalIdValue}&quot;)
            vars.put(&quot;externalIdHeader&quot;, externalIdValue)  // Save to JMeter variable
        }
    }
} else {
    log.warn(&quot;No headers found.&quot;)
}


log.info(JsonOutput.toJson(builder.content))
prev.setResponseData(JsonOutput.prettyPrint(JsonOutput.toJson(builder.content)), &quot;UTF-8&quot;)</stringProp>
            <stringProp name="scriptLanguage">groovy</stringProp>

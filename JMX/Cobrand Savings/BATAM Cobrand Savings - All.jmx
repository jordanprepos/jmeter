    <hashTree>
      <BeanShellPreProcessor guiclass="TestBeanGUI" testclass="BeanShellPreProcessor" testname="BeanShell PreProcessor" enabled="false">
        <boolProp name="resetInterpreter">false</boolProp>
        <stringProp name="parameters"></stringProp>
        <stringProp name="filename"></stringProp>
        <stringProp name="script">String time = &quot;${__time(yyyy-MM-dd&apos;T&apos;HH:mm:ss+07:00)}&quot;;
props.put(&quot;time&quot;,time);

String timeRef= &quot;${__time(yyyyMMdd&apos;T&apos;HHmmss0700)}&quot;;
props.put(&quot;timeRef&quot;,timeRef);

String randFourDigits = &quot;${__Random(0000,9999)}&quot;;
props.put(&quot;randFourDigits&quot;,randFourDigits);</stringProp>
      </BeanShellPreProcessor>
      <hashTree/>
      <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="JSR223 PreProcessor" enabled="true">
        <stringProp name="scriptLanguage">groovy</stringProp>
        <stringProp name="parameters"></stringProp>
        <stringProp name="filename"></stringProp>
        <stringProp name="cacheKey">true</stringProp>
        <stringProp name="script">import java.time.ZonedDateTime
import java.time.ZoneId
import java.time.format.DateTimeFormatter
import java.util.concurrent.ThreadLocalRandom

// Time format
def now = ZonedDateTime.now(ZoneId.of(&quot;Asia/Jakarta&quot;))

def time = now.format(DateTimeFormatter.ofPattern(&quot;yyyy-MM-dd&apos;T&apos;HH:mm:ssXXX&quot;))
props.put(&quot;time&quot;, time)

def timeRef = now.format(DateTimeFormatter.ofPattern(&quot;yyyyMMdd&apos;T&apos;HHmmss0700&quot;))
props.put(&quot;timeRef&quot;, timeRef)

// Random generators
def randFourDigits = ThreadLocalRandom.current().nextInt(0, 100000)
props.put(&quot;randFourDigits&quot;, String.format(&quot;%05d&quot;, randFourDigits))

def randPhoneNumber = &quot;0812&quot; + String.format(&quot;%010d&quot;, ThreadLocalRandom.current().nextLong(0, 10000000000L))
props.put(&quot;randPhoneNumber&quot;, randPhoneNumber)

log.info(&quot;&gt;&gt;&gt;&gt;&gt;&gt;&gt;&gt;&gt;&gt;&gt;&gt;&gt;&gt;&gt;&gt;&gt;&gt;&gt;&gt;&gt;&gt;&gt;&gt;&gt;&gt;&gt;&gt;&gt;&gt;   &quot; + randPhoneNumber)

def randomDeviceId = &quot;testingdevice-ds01-&quot; + String.format(&quot;%04d&quot;, ThreadLocalRandom.current().nextInt(0,10000))
props.put(&quot;randomDeviceId&quot;, randomDeviceId)

def randExternalId = &quot;0812&quot; + String.format(&quot;%08d&quot;, ThreadLocalRandom.current().nextLong(0, 10000000000L))
props.put(&quot;randExternalId&quot;, randExternalId)

def partnerRrn =  (1..64).collect { ThreadLocalRandom.current().nextInt(0,10) }.join();
props.put(&quot;partnerRrn&quot;, partnerRrn)

// 13 digit consentId
def randomNum = ThreadLocalRandom.current().nextLong(0, 100000000L)
def consentId = String.format(&quot;%08d&quot;, randomNum)
props.put(&quot;consentId&quot;, consentId)
log.info(&quot;BeanShell Consent ID &gt;&gt;&gt;&gt;&gt;&gt;&gt;&gt;&gt;&gt;&gt;&gt;&gt;&gt;&gt;&gt;&gt;&gt;&gt;&gt;&gt;&gt;&gt;&gt;&gt;&gt;&gt;&gt;&gt;&gt;: &quot; + consentId)

def specialChar = &quot;!@#\$&quot;;
vars.put(&quot;specialChar&quot;, specialChar)

def maxLength = String.format(&quot;%013d&quot;, randomNum)
vars.put(&quot;maxLength&quot;, maxLength)

</stringProp>
      </JSR223PreProcessor>

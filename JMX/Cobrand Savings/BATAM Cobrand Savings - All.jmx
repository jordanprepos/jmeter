              </elementProp>
              <elementProp name="" elementType="Header">
                <stringProp name="Header.name">X-CLIENT-KEY</stringProp>
                <stringProp name="Header.value">${clientId}</stringProp>
              </elementProp>
              <elementProp name="" elementType="Header">
                <stringProp name="Header.name">X-PARTNER-ID</stringProp>
                <stringProp name="Header.value">${partnerId}</stringProp>
              </elementProp>
              <elementProp name="" elementType="Header">
                <stringProp name="Header.name">X-EXTERNAL-ID</stringProp>
                <stringProp name="Header.value">${__Random(2022000000000,2022999999999)}</stringProp>
              </elementProp>
              <elementProp name="" elementType="Header">
                <stringProp name="Header.name">X-IP-ADDRESS</stringProp>
                <stringProp name="Header.value">192.168.1.113</stringProp>
              </elementProp>
              <elementProp name="" elementType="Header">
                <stringProp name="Header.name">CHANNEL-ID</stringProp>
                <stringProp name="Header.value">APIMGM</stringProp>
              </elementProp>
              <elementProp name="X-SIGNATURE" elementType="Header">
                <stringProp name="Header.name">X-SIGNATURE</stringProp>
                <stringProp name="Header.value">${signature}</stringProp>
              </elementProp>
              <elementProp name="Content-Type" elementType="Header">
